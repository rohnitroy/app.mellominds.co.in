# ─── Database ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mello_db
DB_USER=mello_admin
DB_PASSWORD=your_database_password

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
# LOCAL:      http://localhost:3001/auth/google/callback
# PRODUCTION: https://your-api-domain.com/auth/google/callback
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# ─── Session ──────────────────────────────────────────────────────────────────
SESSION_SECRET=your_random_session_secret_here

# ─── URLs ─────────────────────────────────────────────────────────────────────
# LOCAL:      http://localhost:5173
# PRODUCTION: https://your-frontend-domain.com
# ⚠️  This is used in booking confirmation emails for the cancel/reschedule link.
#    Must be set to the real domain in production or those links will be broken.
FRONTEND_URL=http://localhost:5173

# LOCAL:      http://localhost:3001
# PRODUCTION: https://your-api-domain.com
BACKEND_URL=http://localhost:3001

# Also update this for the calendar OAuth callback in production:
# LOCAL:      http://localhost:3001/api/connect-calendar/callback
# PRODUCTION: https://your-api-domain.com/api/connect-calendar/callback
CONNECT_CALENDAR_CALLBACK_URL=http://localhost:3001/api/connect-calendar/callback

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001

# Set to "production" on your server — enables startup warnings for misconfigured URLs
NODE_ENV=development

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Sign up at https://resend.com, verify your domain, and paste the API key below.
# Free tier: 3,000 emails/month. Works on all hosting platforms including Render.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# The "from" address — must use a domain verified in your Resend dashboard.
EMAIL_FROM=MelloMinds <noreply@mellominds.co.in>

# ─── Cloudinary ───────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
