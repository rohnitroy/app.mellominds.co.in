# ─── Database ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mello_db
DB_USER=mello_admin
DB_PASSWORD=your_database_password

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
# LOCAL:      http://localhost:3001/auth/google/callback
# PRODUCTION: https://your-api-domain.com/auth/google/callback
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# ─── Session ──────────────────────────────────────────────────────────────────
SESSION_SECRET=your_random_session_secret_here

# ─── URLs ─────────────────────────────────────────────────────────────────────
# LOCAL:      http://localhost:5173
# PRODUCTION: https://your-frontend-domain.com
# ⚠️  This is used in booking confirmation emails for the cancel/reschedule link.
#    Must be set to the real domain in production or those links will be broken.
FRONTEND_URL=http://localhost:5173

# LOCAL:      http://localhost:3001
# PRODUCTION: https://your-api-domain.com
BACKEND_URL=http://localhost:3001

# Also update this for the calendar OAuth callback in production:
# LOCAL:      http://localhost:3001/api/connect-calendar/callback
# PRODUCTION: https://your-api-domain.com/api/connect-calendar/callback
CONNECT_CALENDAR_CALLBACK_URL=http://localhost:3001/api/connect-calendar/callback

# Gmail OAuth callback (enterprise — send emails from user's own Gmail)
# Add this URL to your Google Cloud Console → Authorized redirect URIs
# LOCAL:      http://localhost:3001/api/gmail/callback
# PRODUCTION: https://your-api-domain.com/api/gmail/callback
GMAIL_CALLBACK_URL=http://localhost:3001/api/gmail/callback

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001

# Set to "production" on your server — enables startup warnings for misconfigured URLs
NODE_ENV=development

# ─── Email (Gmail) ────────────────────────────────────────────────────────────
# Use a Gmail App Password (NOT your regular Gmail password).
# Steps to generate one:
#   1. Enable 2-Step Verification on your Google account
#   2. Go to Google Account → Security → App Passwords
#   3. Generate a password for "Mail" and paste it below (spaces are fine)
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ─── Cloudinary ───────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
